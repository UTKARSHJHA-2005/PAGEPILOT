{
  "manifest_version": 3,
  "name": "PAGEPILOT",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["AIbot.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": ["https://openrouter.ai/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lottie.min.js", "content.js"]
    }
  ]
}
